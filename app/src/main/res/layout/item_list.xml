<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="14dp"
    android:background="?attr/selectableItemBackground">
    <TextView android:id="@+id/tvTitle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#E6EDF3" android:textSize="16sp" android:maxLines="1"
        android:ellipsize="end"/>
    <TextView android:id="@+id/tvSubtitle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#8B949E" android:textSize="13sp" android:maxLines="1"
        android:ellipsize="end" android:layout_marginTop="2dp"/>
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#21262D" android:layout_marginTop="10dp"/>
</LinearLayout>
