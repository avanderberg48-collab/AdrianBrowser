<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0D1117">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:text="Homepage URL" android:textColor="#8B949E" android:textSize="13sp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <EditText android:id="@+id/etHomepage"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:background="#21262D" android:textColor="#E6EDF3"
            android:paddingStart="12dp" android:layout_marginBottom="16dp"
            android:inputType="textUri" android:contentDescription="Homepage URL field"/>

        <TextView android:text="Text Size" android:textColor="#8B949E" android:textSize="13sp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <TextView android:id="@+id/tvZoomValue" android:text="Text Size: 100%"
            android:textColor="#58A6FF" android:textSize="14sp"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <SeekBar android:id="@+id/sbTextZoom"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="150" android:progress="50" android:layout_marginBottom="16dp"
            android:contentDescription="Text size slider"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:text="Dark Mode" android:textColor="#E6EDF3" android:textSize="16sp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Switch android:id="@+id/swDarkMode" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:contentDescription="Dark mode switch"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:text="JavaScript" android:textColor="#E6EDF3" android:textSize="16sp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Switch android:id="@+id/swJavascript" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:text="Accept Cookies" android:textColor="#E6EDF3" android:textSize="16sp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Switch android:id="@+id/swCookies" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:text="Load Images" android:textColor="#E6EDF3" android:textSize="16sp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Switch android:id="@+id/swImages" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:text="Request Desktop Site" android:textColor="#E6EDF3" android:textSize="16sp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Switch android:id="@+id/swDesktopSite" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="48dp"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:text="Save Passwords" android:textColor="#E6EDF3" android:textSize="16sp"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <Switch android:id="@+id/swSavePasswords" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>

        <Button android:id="@+id/btnSave"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Save Settings" android:backgroundTint="#238636"
            android:textColor="#fff" android:layout_marginTop="16dp"
            android:contentDescription="Save settings button"/>

        <Button android:id="@+id/btnClearCache"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Clear Cache and Cookies" android:backgroundTint="#DA3633"
            android:textColor="#fff" android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>
